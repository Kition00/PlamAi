# ─────────────────────────────────────────────
#  VedicAI — Environment Variables
#  Copy this file, fill in your keys, rename to .env.local
# ─────────────────────────────────────────────

# ── AI ────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── RAZORPAY (India — UPI, GPay, Cards) ───────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── STRIPE (International — Cards, Apple/Google Pay) ──
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ── PAYPAL (Global) ────────────────────────────
# Get from: https://developer.paypal.com/dashboard
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_secret_here
PAYPAL_MODE=sandbox
# Change to: live (for production)

# ── TWILIO WHATSAPP ────────────────────────────
# Get from: https://console.twilio.com
# Enable WhatsApp Sandbox or Business API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# (sandbox number — use your approved number in production)

# ── EMAIL (SMTP) ───────────────────────────────
# Gmail: enable App Passwords at myaccount.google.com/apppasswords
# Or use: SendGrid, Resend, Mailgun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=VedicAI <noreply@vedicai.com>

# ── PRICING ────────────────────────────────────
# INR for India (Razorpay amounts in paise: 49900 = ₹499)
PRICE_INR_PAISE=49900
# USD for International (Stripe amounts in cents: 599 = $5.99)
PRICE_USD_CENTS=599
# PayPal amount in USD string
PRICE_USD_PAYPAL=5.99

# ── APP ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here
